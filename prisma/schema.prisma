generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
  BUYER
}

enum Dimension {
  MASS   // Base unit: g
  VOLUME // Base unit: mL
  COUNT  // Base unit: item
}

enum OrderStatus {
  QUOTE
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  UPI
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  RETURNED
}

enum QueryStatus {
  OPEN
  RESOLVED
}

model User {
  id           String  @id @default(uuid())
  name         String?
  username     String  @unique
  passwordHash String
  role         Role    @default(BUYER)
  phone        String?
  address      String?
  isRestricted Boolean @default(false)
  orders       Order[]
  products     Product[]
  queries      Query[]
}

model Product {
  id                 String      @id @default(uuid())
  name               String
  sku                String      @unique
  dimension          Dimension
  symptoms           String?
  imageUrl           String?
  
  seller             User        @relation(fields: [sellerId], references: [id])
  sellerId           String

  // Price per Base Unit in INR (e.g., INR per g). Precision up to 4 decimal places for micro-paise.
  pricePerBaseUnit   Decimal     @db.Decimal(15, 4)
  // Stock always in Base Units. High precision for exact amounts.
  stockInBaseUnit    Decimal     @db.Decimal(18, 6)
  orderItems         OrderItem[]
}

model Order {
  id             String      @id @default(uuid())
  user           User        @relation(fields: [userId], references: [id])
  userId         String
  status         OrderStatus @default(QUOTE)
  paymentMethod  PaymentMethod @default(COD)
  paymentStatus  PaymentStatus @default(PENDING)
  // Total in INR
  totalAmountInr Decimal     @db.Decimal(15, 4)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
}

model OrderItem {
  id                      String   @id @default(uuid())
  order                   Order    @relation(fields: [orderId], references: [id])
  orderId                 String
  product                 Product  @relation(fields: [productId], references: [id])
  productId               String
  // Exact quantity and unit requested by the user
  requestedDisplayQuantity Decimal @db.Decimal(18, 6)
  requestedDisplayUnit     String
  // Resolved quantity in Base Unit for strict inventory tracking
  baseQuantity            Decimal  @db.Decimal(18, 6)
  // Snapshot of price at the time of order
  pricePerBaseUnitAtTime  Decimal  @db.Decimal(15, 4)
  // Final calculated cost for this line item
  itemTotalInr            Decimal  @db.Decimal(15, 4)
  
  status                  OrderItemStatus @default(PENDING)
}

model Query {
  id        String      @id @default(uuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  subject   String
  message   String
  response  String?
  status    QueryStatus @default(OPEN)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
